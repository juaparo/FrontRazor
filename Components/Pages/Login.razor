@*
    Login.razor - Pagina de inicio de sesion.

    CONCEPTOS BLAZOR:
    - @page "/login"          -> Define la URL de esta pagina
    - @layout EmptyLayout     -> Usa un layout vacio (sin sidebar) porque el login no necesita menu
    - @inject AuthService     -> Inyecta el servicio de autenticacion (Dependency Injection)
    - @inject NavigationManager -> Para redirigir a otra pagina despues del login
    - @rendermode InteractiveServer -> Necesario para que @onclick y @bind funcionen (SignalR)
    - @bind="email"           -> Two-way binding: sincroniza la variable con el input
    - @onclick="DoLogin"      -> Al hacer clic, ejecuta el metodo DoLogin()

    FLUJO:
    1. Usuario escribe email y contrasena
    2. Clic en "Iniciar sesion" -> llama DoLogin()
    3. DoLogin() llama auth.Login() que verifica con BCrypt en la API
    4. Si OK -> redirige a "/" (inicio)
    5. Si debe cambiar contrasena -> redirige a "/cambiar-contrasena"
    6. Si falla -> muestra error en alerta roja
*@

@page "/login"
@layout FrontBlazor_AppiGenericaCsharp.Components.Layout.EmptyLayout
@inject FrontBlazor_AppiGenericaCsharp.Services.AuthService auth
@inject NavigationManager nav
@rendermode InteractiveServer

<div class="d-flex justify-content-center align-items-center" style="min-height:100vh; background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%);">
    <div class="card shadow-lg border-0" style="width:420px; border-radius: 16px; overflow: hidden;">
        <div class="card-header text-center py-4 border-0" style="background: linear-gradient(135deg, #198754 0%, #146c43 100%); color:white;">
            <h3 class="mb-0 fw-bold">
                <i class="bi bi-mortarboard-fill me-2"></i>App Conocimiento
            </h3>
        </div>
        <div class="card-body p-4 p-md-5 bg-white">
            @if (!string.IsNullOrEmpty(error))
            {
                <div class="alert alert-danger small py-2 alert-dismissible fade show d-flex align-items-center">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    <div>@error</div>
                    <button type="button" class="btn-close ms-auto" style="position: relative; padding: 0.5rem;" @onclick='() => error = ""'></button>
                </div>
            }

            <div class="form-floating mb-4">
                <input type="email" class="form-control" id="floatingEmail" placeholder="name@example.com" @bind="email" />
                <label for="floatingEmail" class="text-muted"><i class="bi bi-envelope me-2"></i>Correo electrónico</label>
            </div>
            
            <div class="form-floating mb-4">
                <input type="password" class="form-control" id="floatingPassword" placeholder="Contraseña" @bind="contrasena" @onkeypress="OnKeyPress" />
                <label for="floatingPassword" class="text-muted"><i class="bi bi-lock me-2"></i>Contraseña</label>
            </div>

            <button class="btn btn-success w-100 py-2 mt-2 fw-bold shadow-sm" style="border-radius: 8px; font-size: 1.05rem;" @onclick="DoLogin" disabled="@cargando">
                @if (cargando)
                {
                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                }
                <i class="bi bi-box-arrow-in-right me-2"></i> Iniciar sesión
            </button>
            
            <div class="text-center mt-4">
                <a href="/recuperar-contrasena" class="text-success text-decoration-none fw-medium hover-underline" style="transition: color 0.2s ease;">
                    ¿Olvidó su contraseña?
                </a>
            </div>
        </div>
    </div>
</div>

@code {
    string email = "", contrasena = "", error = "";
    bool cargando;

    async Task DoLogin()
    {
        error = "";
        cargando = true;
        var (ok, msg) = await auth.Login(email, contrasena);
        cargando = false;
        if (ok)
        {
            // Si recupero contrasena, forzar cambio
            if (auth.DebeCambiarContrasena || auth.DebeForcarCambio(email))
            {
                auth.DebeCambiarContrasena = true;
                nav.NavigateTo("/cambiar-contrasena", forceLoad: false);
            }
            else
                nav.NavigateTo("/", forceLoad: false);
        }
        else error = msg;
    }

    async Task OnKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await DoLogin();
    }
}

