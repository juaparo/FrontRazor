@page "/semillero-linea"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api
@inject FrontBlazor_AppiGenericaCsharp.Services.SpService Sp

<PageTitle>Semilleros y Líneas</PageTitle>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Semilleros por Línea</h2>
        <button class="btn btn-primary" @onclick="MostrarFormularioCrear">
            <i class="bi bi-plus-circle me-1"></i> Vincular Línea a Semillero
        </button>
    </div>

    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert alert-@(exito ? "success" : "danger") alert-dismissible fade show" role="alert">
            @mensaje
            <button type="button" class="btn-close" @onclick="CerrarMensaje"></button>
        </div>
    }

    @if (mostrarFormulario)
    {
        <div class="card mb-4 shadow-sm">
            <div class="card-header bg-light">
                <h5 class="mb-0">Vincular Semillero con Línea</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <!-- Semillero -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Semillero <span class="text-danger">*</span></label>
                        <select class="form-select" @bind="campoSemillero">
                            <option value="">-- Seleccione un Semillero --</option>
                            @foreach (var s in semilleros)
                            {
                                <option value="@s["id"]?.ToString()">@s["nombre"]</option>
                            }
                        </select>
                    </div>

                    <!-- Linea Investigacion -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Línea de Investigación <span class="text-danger">*</span></label>
                        <select class="form-select" @bind="campoLinea">
                            <option value="">-- Seleccione una Línea --</option>
                            @foreach (var l in lineas)
                            {
                                <option value="@l["id"]?.ToString()">@l["nombre"]</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-2 mt-3">
                    <button class="btn btn-secondary" @onclick="OcultarFormulario">Cancelar</button>
                    <button class="btn btn-success" @onclick="GuardarRegistro">
                        <i class="bi bi-link me-1"></i> Vincular
                    </button>
                </div>
            </div>
        </div>
    }

    @if (cargando)
    {
        <div class="text-center my-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
        </div>
    }
    else if (registros.Count == 0)
    {
        <div class="alert alert-info">No hay vínculos registrados.</div>
    }
    else
    {
        <div class="table-responsive shadow-sm rounded">
            <table class="table table-striped table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Semillero</th>
                        <th>Línea de Investigación</th>
                        <th class="text-center" style="width: 150px;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var reg in registros)
                    {
                        var idSemillero = reg["semillero"]?.ToString();
                        var idLinea = reg["linea_investigacion"]?.ToString();
                        
                        <tr>
                            <td class="align-middle">@ObtenerNombreSemillero(idSemillero)</td>
                            <td class="align-middle">@ObtenerNombreLinea(idLinea)</td>
                            <td class="text-center">
                                <button class="btn btn-danger btn-sm" @onclick='() => ConfirmarEliminacion(idSemillero, idLinea)'>
                                    Eliminar
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@if (mostrarModalEliminar)
{
    <div class="modal fade show" style="display: block; background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">Confirmar Desvinculación</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CancelarEliminacion"></button>
                </div>
                <div class="modal-body">
                    <p>¿Está seguro que desea eliminar este vínculo?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CancelarEliminacion">Cancelar</button>
                    <button type="button" class="btn btn-danger" @onclick="EjecutarEliminacion">Eliminar Vínculo</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Dictionary<string, object?>> registros = new();
    private List<Dictionary<string, object?>> semilleros = new();
    private List<Dictionary<string, object?>> lineas = new();

    private bool cargando = true;
    private bool mostrarFormulario = false;
    private bool mostrarModalEliminar = false;

    private string mensaje = "";
    private bool exito = false;

    private string campoSemillero = "";
    private string campoLinea = "";

    private string idSemilleroEliminar = "";
    private string idLineaEliminar = "";

    protected override async Task OnInitializedAsync()
    {
        await CargarCatalogos();
        await CargarRegistros();
    }

    private async Task CargarCatalogos()
    {
        semilleros = await Api.ListarAsync("semillero");
        lineas = await Api.ListarAsync("linea_investigacion");
    }

    private async Task CargarRegistros()
    {
        cargando = true;
        registros = await Api.ListarAsync("semillero_linea");
        cargando = false;
    }

    private string ObtenerNombreSemillero(string? id)
    {
        if (string.IsNullOrEmpty(id)) return "";
        var item = semilleros.FirstOrDefault(x => x["id"]?.ToString() == id);
        return item != null ? item["nombre"]?.ToString() ?? id : id;
    }

    private string ObtenerNombreLinea(string? id)
    {
        if (string.IsNullOrEmpty(id)) return "";
        var item = lineas.FirstOrDefault(x => x["id"]?.ToString() == id);
        return item != null ? item["nombre"]?.ToString() ?? id : id;
    }

    private void MostrarFormularioCrear()
    {
        campoSemillero = "";
        campoLinea = "";
        mostrarFormulario = true;
        CerrarMensaje();
    }

    private void OcultarFormulario()
    {
        mostrarFormulario = false;
    }

    private async Task GuardarRegistro()
    {
        if (string.IsNullOrWhiteSpace(campoSemillero) || string.IsNullOrWhiteSpace(campoLinea))
        {
            exito = false;
            mensaje = "Por favor, seleccione ambos campos obligatorios.";
            return;
        }

        CerrarMensaje();

        var datos = new Dictionary<string, object?>
        {
            ["semillero"] = int.Parse(campoSemillero),
            ["linea_investigacion"] = int.Parse(campoLinea)
        };

        var resultado = await Api.CrearAsync("semillero_linea", datos);
        exito = resultado.exito;
        mensaje = resultado.mensaje;

        if (exito)
        {
            mostrarFormulario = false;
            await CargarRegistros();
        }
    }

    private void ConfirmarEliminacion(string? pSemillero, string? pLinea)
    {
        if (string.IsNullOrEmpty(pSemillero) || string.IsNullOrEmpty(pLinea)) return;
        idSemilleroEliminar = pSemillero;
        idLineaEliminar = pLinea;
        mostrarModalEliminar = true;
        CerrarMensaje();
    }

    private void CancelarEliminacion()
    {
        mostrarModalEliminar = false;
    }

    private async Task EjecutarEliminacion()
    {
        var parametrosSp = new Dictionary<string, object?> {
            ["semillero"] = int.Parse(idSemilleroEliminar),
            ["linea_investigacion"] = int.Parse(idLineaEliminar)
        };

        var resultado = await Sp.EjecutarSpAsync("sp_eliminar_semillero_linea", parametrosSp);
        exito = resultado.exito;
        mensaje = resultado.mensaje;

        CancelarEliminacion();

        if (exito)
        {
            await CargarRegistros();
        }
    }

    private void CerrarMensaje()
    {
        mensaje = "";
    }
}
