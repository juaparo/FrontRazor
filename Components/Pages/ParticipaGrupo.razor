@page "/participa-grupo"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api
@inject FrontBlazor_AppiGenericaCsharp.Services.SpService Sp

<PageTitle>Participación en Grupos</PageTitle>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Gestión de Participación en Grupos</h2>
        <button class="btn btn-primary" @onclick="MostrarFormularioCrear">
            <i class="bi bi-plus-circle me-1"></i> Nueva Participación
        </button>
    </div>

    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert alert-@(exito ? "success" : "danger") alert-dismissible fade show" role="alert">
            @mensaje
            <button type="button" class="btn-close" @onclick="CerrarMensaje"></button>
        </div>
    }

    @if (mostrarFormulario)
    {
        <div class="card mb-4 shadow-sm">
            <div class="card-header bg-light">
                <h5 class="mb-0">@(editando ? "Editar Participación" : "Nueva Participación")</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <!-- Docente -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Docente <span class="text-danger">*</span></label>
                        <select class="form-select" @bind="campoDocente" disabled="@editando">
                            <option value="">-- Seleccione un Docente --</option>
                            @foreach (var d in docentes)
                            {
                                <option value="@d["cedula"]?.ToString()">
                                    @d["nombres"] @d["apellidos"] (C.C. @d["cedula"])
                                </option>
                            }
                        </select>
                    </div>

                    <!-- Grupo Investigacion -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Grupo de Investigación <span class="text-danger">*</span></label>
                        <select class="form-select" @bind="campoGrupo" disabled="@editando">
                            <option value="">-- Seleccione un Grupo --</option>
                            @foreach (var g in grupos)
                            {
                                <option value="@g["id"]?.ToString()">@g["nombre"]</option>
                            }
                        </select>
                    </div>

                    <!-- Rol -->
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Rol <span class="text-danger">*</span></label>
                        <input class="form-control" @bind="campoRol" maxlength="15" placeholder="Ej. Líder, Integrante..." />
                    </div>

                    <!-- Fecha Inicio -->
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Fecha de Inicio <span class="text-danger">*</span></label>
                        <input type="date" class="form-control" @bind="campoFechaInicio" />
                    </div>

                    <!-- Fecha Fin -->
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Fecha de Fin (Opcional)</label>
                        <input type="date" class="form-control" @bind="campoFechaFin" />
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-2 mt-3">
                    <button class="btn btn-secondary" @onclick="OcultarFormulario">Cancelar</button>
                    <button class="btn btn-success" @onclick="GuardarRegistro">
                        <i class="bi bi-save me-1"></i> Guardar
                    </button>
                </div>
            </div>
        </div>
    }

    @if (cargando)
    {
        <div class="text-center my-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
            <p class="mt-2">Cargando registros...</p>
        </div>
    }
    else if (registros.Count == 0)
    {
        <div class="alert alert-info">
            No hay registros de participación en grupos disponibles.
        </div>
    }
    else
    {
        <div class="table-responsive shadow-sm rounded">
            <table class="table table-striped table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Docente</th>
                        <th>Grupo de Investigación</th>
                        <th>Rol</th>
                        <th>Fecha Inicio</th>
                        <th>Fecha Fin</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var reg in registros)
                    {
                        var cedulaDocente = reg["docente_cedula"]?.ToString();
                        var idGrupo = reg["grupo_investigacion_id"]?.ToString();
                        
                        <tr>
                            <td>@ObtenerNombreDocente(cedulaDocente)</td>
                            <td>@ObtenerNombreGrupo(idGrupo)</td>
                            <td>@reg["rol"]</td>
                            <td>@(reg["fecha_inicio"] != null ? Convert.ToDateTime(reg["fecha_inicio"]).ToString("dd/MM/yyyy") : "")</td>
                            <td>@(reg["fecha_fin"] != null ? Convert.ToDateTime(reg["fecha_fin"]).ToString("dd/MM/yyyy") : "N/A")</td>
                            <td class="text-center">
                                <button class="btn btn-sm btn-outline-primary me-1" title="Editar"
                                        @onclick='() => PrepararEdicion(reg)'>
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-danger" title="Eliminar"
                                        @onclick='() => ConfirmarEliminacion(cedulaDocente, idGrupo)'>
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@if (mostrarModalEliminar)
{
    <div class="modal fade show" style="display: block; background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">Confirmar Eliminación</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CancelarEliminacion"></button>
                </div>
                <div class="modal-body">
                    <p>¿Está seguro que desea eliminar la vinculación del docente en este grupo?</p>
                    <p class="text-muted small">Esta acción no se puede deshacer.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CancelarEliminacion">Cancelar</button>
                    <button type="button" class="btn btn-danger" @onclick="EjecutarEliminacion">Eliminar</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    // Listados de datos
    private List<Dictionary<string, object?>> registros = new();
    private List<Dictionary<string, object?>> docentes = new();
    private List<Dictionary<string, object?>> grupos = new();

    // Estado UI
    private bool cargando = true;
    private bool mostrarFormulario = false;
    private bool editando = false;
    private bool mostrarModalEliminar = false;

    // Mensajes
    private string mensaje = "";
    private bool exito = false;

    // Campos del formulario
    private string campoDocente = "";
    private string campoGrupo = "";
    private string campoRol = "";
    private DateTime campoFechaInicio = DateTime.Today;
    private DateTime? campoFechaFin = null;

    // Variables para Eliminación
    private string idDocenteEliminar = "";
    private string idGrupoEliminar = "";

    protected override async Task OnInitializedAsync()
    {
        await CargarCatalogos();
        await CargarRegistros();
    }

    private async Task CargarCatalogos()
    {
        docentes = await Api.ListarAsync("docente");
        grupos = await Api.ListarAsync("grupo_investigacion");
    }

    private async Task CargarRegistros()
    {
        cargando = true;
        registros = await Api.ListarAsync("participa_grupo");
        cargando = false;
    }

    private string ObtenerNombreDocente(string? cedula)
    {
        if (string.IsNullOrEmpty(cedula)) return "Desconocido";
        var docente = docentes.FirstOrDefault(d => d["cedula"]?.ToString() == cedula);
        return docente != null ? $"{docente["nombres"]} {docente["apellidos"]}" : cedula;
    }

    private string ObtenerNombreGrupo(string? id)
    {
        if (string.IsNullOrEmpty(id)) return "Desconocido";
        var grupo = grupos.FirstOrDefault(g => g["id"]?.ToString() == id);
        return grupo != null ? grupo["nombre"]?.ToString() ?? id : id;
    }

    private void MostrarFormularioCrear()
    {
        LimpiarFormulario();
        editando = false;
        mostrarFormulario = true;
        CerrarMensaje();
    }

    private void OcultarFormulario()
    {
        mostrarFormulario = false;
        LimpiarFormulario();
    }

    private void PrepararEdicion(Dictionary<string, object?> registro)
    {
        CerrarMensaje();
        editando = true;
        
        campoDocente = registro["docente_cedula"]?.ToString() ?? "";
        campoGrupo = registro["grupo_investigacion_id"]?.ToString() ?? "";
        campoRol = registro["rol"]?.ToString() ?? "";

        if (registro["fecha_inicio"] != null && DateTime.TryParse(registro["fecha_inicio"]?.ToString(), out DateTime fi))
            campoFechaInicio = fi;
        
        if (registro["fecha_fin"] != null && DateTime.TryParse(registro["fecha_fin"]?.ToString(), out DateTime ff))
            campoFechaFin = ff;
        else
            campoFechaFin = null;

        mostrarFormulario = true;
    }

    private async Task GuardarRegistro()
    {
        if (string.IsNullOrWhiteSpace(campoDocente) || string.IsNullOrWhiteSpace(campoGrupo) || string.IsNullOrWhiteSpace(campoRol))
        {
            exito = false;
            mensaje = "Por favor, complete todos los campos obligatorios.";
            return;
        }

        CerrarMensaje();

        var datos = new Dictionary<string, object?>
        {
            ["docente_cedula"] = int.Parse(campoDocente),
            ["grupo_investigacion_id"] = int.Parse(campoGrupo),
            ["rol"] = campoRol,
            ["fecha_inicio"] = campoFechaInicio.ToString("yyyy-MM-dd")
        };

        if (campoFechaFin.HasValue)
        {
            datos["fecha_fin"] = campoFechaFin.Value.ToString("yyyy-MM-dd");
        }
        else
        {
            datos["fecha_fin"] = null;
        }

        if (editando)
        {
            var spDatos = new Dictionary<string, object?>(datos);
            var resultado = await Sp.EjecutarSpAsync("sp_actualizar_participa_grupo", spDatos);
            
            exito = resultado.exito;
            mensaje = resultado.mensaje;
        }
        else
        {
            var resultado = await Api.CrearAsync("participa_grupo", datos);
            exito = resultado.exito;
            mensaje = resultado.mensaje;
        }

        if (exito)
        {
            mostrarFormulario = false;
            await CargarRegistros();
        }
    }

    private void ConfirmarEliminacion(string? pDocente, string? pGrupo)
    {
        if (string.IsNullOrEmpty(pDocente) || string.IsNullOrEmpty(pGrupo)) return;
        
        idDocenteEliminar = pDocente;
        idGrupoEliminar = pGrupo;
        mostrarModalEliminar = true;
        CerrarMensaje();
    }

    private void CancelarEliminacion()
    {
        mostrarModalEliminar = false;
        idDocenteEliminar = "";
        idGrupoEliminar = "";
    }

    private async Task EjecutarEliminacion()
    {
        var parametrosSp = new Dictionary<string, object?> {
            ["docente_cedula"] = int.Parse(idDocenteEliminar),
            ["grupo_investigacion_id"] = int.Parse(idGrupoEliminar)
        };

        var resultado = await Sp.EjecutarSpAsync("sp_eliminar_participa_grupo", parametrosSp);

        exito = resultado.exito;
        mensaje = resultado.mensaje;

        CancelarEliminacion();

        if (exito)
        {
            await CargarRegistros();
        }
    }

    private void LimpiarFormulario()
    {
        campoDocente = "";
        campoGrupo = "";
        campoRol = "";
        campoFechaInicio = DateTime.Today;
        campoFechaFin = null;
    }

    private void CerrarMensaje()
    {
        mensaje = "";
    }
}
